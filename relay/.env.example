RELAY_ENVIRONMENT=development
PUBLIC_BASE_URL=http://127.0.0.1:8000/v1
# Use sqlite:///./hermes_mobile.db for a SQLite file in the relay directory
# (the path is resolved relative to the relay package, not the CWD — GH #59).
# Use postgresql://... for PostgreSQL in production.
DATABASE_URL=sqlite:///./hermes_mobile.db
INTERNAL_API_KEY=replace-me
CONNECTOR_SETUP_SECRET=
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
PAIRING_CODE_TTL_SECONDS=900
PHONE_PAIRING_CODE_TTL_SECONDS=600
PHONE_PAIRING_MAX_ATTEMPTS_PER_CODE=5
PHONE_PAIRING_MAX_ATTEMPTS_PER_IP=5
PHONE_PAIRING_RATE_LIMIT_WINDOW_SECONDS=300
HOST_ENROLLMENT_CODE_TTL_SECONDS=900
DEFAULT_USER_DISPLAY_NAME=Hermes User
HERMES_ADAPTER=connector
HERMES_COMMAND=hermes
HERMES_WORKDIR=
HERMES_PROVIDER=
HERMES_MODEL=
HERMES_TOOLSETS=
HERMES_SOURCE=tool
HERMES_HISTORY_LIMIT=20
CONNECTOR_SYNC_WAIT_SECONDS=25
CONNECTOR_JOB_LEASE_SECONDS=180
CONNECTOR_HEARTBEAT_TIMEOUT_SECONDS=30
CONNECTOR_IDLE_POLL_INTERVAL_SECONDS=1.0

# APNs (optional — omit to disable push notifications)
# Use APNS_KEY_PATH for local dev, APNS_KEY_CONTENTS for Fly.io/Docker
APNS_KEY_PATH=
APNS_KEY_CONTENTS=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=io.hermesmobile.HermesMobile
APNS_ENVIRONMENT=development
APP_PRESENCE_STALE_SECONDS=120

# #21 Tier 2: directory the relay may serve agent-written files from (file
# download / share). Leave blank to disable the /v1/device/files route.
# On OJAMD this is the dedicated mobile-download dir, e.g. O:\Hermes\MobileDL
AGENT_FILES_DIR=
