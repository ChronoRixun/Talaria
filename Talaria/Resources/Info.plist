<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Talaria</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundleAlternateIcons</key>
		<dict>
			<key>DeepField</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Icon-DeepField</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>PaperTape</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Icon-PaperTape</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>SolarForge</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Icon-SolarForge</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>Terminal</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>Icon-Terminal</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
		</dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconName</key>
			<string>AppIcon</string>
		</dict>
	</dict>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>Hermes uses the camera to capture photos and documents for analysis.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Hermes reads your health data to offer personalized wellness insights.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Hermes does not write health data, but this permission is required by the system.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Hermes uses your location in the background to provide contextual awareness and proactive suggestions.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Hermes uses your location to provide contextual recommendations and nearby suggestions.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Hermes uses the microphone for voice conversations in Talk Mode.</string>
	<key>NSMotionUsageDescription</key>
	<string>Hermes uses motion data to understand your current activity for contextual awareness.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Hermes accesses your photo library to help organize and search your photos.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Hermes uses speech recognition for voice commands and local transcription.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>UIAppFonts</key>
	<array>
		<string>ChakraPetch-Medium.ttf</string>
		<string>ChakraPetch-SemiBold.ttf</string>
		<string>ChakraPetch-Bold.ttf</string>
		<string>SpaceGrotesk-Regular.ttf</string>
		<string>SpaceGrotesk-Medium.ttf</string>
		<string>SpaceGrotesk-Bold.ttf</string>
		<string>JetBrainsMono-Regular.ttf</string>
		<string>JetBrainsMono-Medium.ttf</string>
		<string>JetBrainsMono-Bold.ttf</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>CPTemplateApplicationSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>CPTemplateApplicationScene</string>
					<key>UISceneConfigurationName</key>
					<string>CarPlay</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).CarPlaySceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
		<string>location</string>
		<string>remote-notification</string>
		<string>audio</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
